{
  "expo": {
    "name": "Ascend",
    "slug": "ascend",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ascend.game",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.game-center": true
      }
    },
    "android": {
      "package": "com.ascend.game"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "resizeMode": "contain"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you. You can play and earn revives without allowing tracking."
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier will be used to deliver personalized ads to you. You can play and earn revives without allowing tracking."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4abc39f9-888c-4651-aa4a-6d5528dce692"
      }
    }
  }
}
